{
  "name": "shoggoth",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Shoggoth agent orchestration platform",
  "workspaces": [
    "packages/*",
    "packages/skills",
    "packages/plugins"
  ],
  "scripts": {
    "clean": "rm -rf packages/*/dist dist",
    "cli": "node --import tsx/esm packages/cli/src/cli.ts",
    "daemon": "node --import tsx/esm packages/daemon/src/index.ts",
    "reinstall": "rm -rf node_modules **/node_modules && npm ci",
    "test": "vitest run",
    "test:ci-agent-isolation": "SHOGGOTH_CI_STRICT_AGENT_TESTS=1 npx vitest run packages/os-exec",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "engines": {
    "node": "~22"
  },
  "dependencies": {
    "tsx": "^4.19.3"
  },
  "devDependencies": {
    "@types/node": "~22",
    "typescript": "~5.7.2",
    "vitest": "^4.1.2"
  }
}
