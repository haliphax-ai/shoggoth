# Optional overrides only — copy to `tests/.env.readiness.local` (gitignored).
#
# Primary stack env lives at repo root: copy `.env.shoggoth.example` → `.env.shoggoth.local`
# (dedicated Shoggoth Discord bot + model URLs). Compose loads `.env.shoggoth.local` first, then this file (later wins).

DISCORD_BOT_TOKEN=
OPENAI_BASE_URL=http://host.docker.internal:8000/v1
OPENAI_API_KEY=
ANTHROPIC_BASE_URL=http://host.docker.internal:8000
ANTHROPIC_API_KEY=
SHOGGOTH_MODEL=claude-sonnet-4-20250514

# Optional: override compose default (readiness-ci-token) for operator_token control auth checks
SHOGGOTH_OPERATOR_TOKEN=
